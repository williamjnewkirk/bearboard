# Copy to .env / .env.local per app and fill in. Never commit real values.

# --- Supabase ---
# Public (safe for client): used by web + mobile
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Server-only (NEVER expose to client / mobile bundle): edge functions, migrations, admin jobs
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_REF=your-project-ref

# --- Clerk ---
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- Expo push ---
# (No key needed for Expo Push in dev; add if you set up an access token)
EXPO_ACCESS_TOKEN=

# --- Monitoring ---
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# --- App config ---
DEFAULT_TEAM_TIMEZONE=America/Chicago
